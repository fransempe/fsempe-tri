---
import BaseLayout from "../layouts/BaseLayout.astro";
import ImageCarousel from "../components/ImageCarousel.astro";
import ResultsTimeline from "../components/ResultsTimeline.astro";
import { RESULTS_TIMELINE } from "../data/results-timeline";
import {
  SITE_TITLE,
  SITE_DESCRIPTION,
  CONTACT_EMAIL,
  INSTAGRAM_URL,
  WHATSAPP_URL,
  CAROUSEL_IMAGES,
} from "../config";
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} sideBarActiveItemID="home">
  <!-- Hero -->
  <section
    id="inicio"
    class="scroll-mt-24 -mx-1 mb-10 flex flex-col items-center rounded-2xl border border-base-300/50 bg-gradient-to-br from-primary/20 via-base-100 to-secondary/15 px-3 py-8 text-center sm:-mx-0 sm:mb-12 sm:px-5 sm:py-10 md:py-14"
  >
    <p class="mb-1 text-base opacity-90 sm:text-lg">🏊‍♂️ 🚴‍♂️ 🏃‍♂️ 🏆</p>
    <h1 class="text-balance text-3xl font-extrabold tracking-tight text-base-content sm:text-4xl md:text-5xl">
      Francisco Sempé
    </h1>
    <p class="mt-2 text-lg font-semibold text-primary sm:text-xl md:text-2xl">Triatleta Amateur</p>
    <div class="mt-4 flex w-full max-w-md flex-col items-stretch justify-center gap-2 text-xs opacity-90 sm:mt-5 sm:max-w-none sm:flex-row sm:flex-wrap sm:gap-3 sm:text-sm md:text-base">
      <span class="badge badge-sm badge-outline gap-1 sm:badge-lg">📍 Mar del Plata, Argentina</span>
      <span class="badge badge-sm badge-outline sm:badge-lg">🏷️ Categoría 40–44</span>
    </div>
    <div
      class="mt-6 w-full max-w-xl self-center rounded-xl border border-warning/30 bg-base-200/80 p-3 text-center sm:mt-8 sm:p-4 md:p-5"
    >
      <p class="mb-1 text-[0.65rem] font-bold uppercase tracking-widest text-warning sm:text-xs">🌍 Clasificado al Mundial</p>
      <p class="text-base font-bold sm:text-lg">IRONMAN 70.3 World Championship</p>
      <p class="mt-1 text-sm opacity-80 sm:text-base">📍 Niza, Francia — 2026</p>
    </div>
  </section>

  <!-- Perfil -->
  <section id="perfil" class="scroll-mt-24 mb-12 sm:mb-14">
    <h2 class="mb-4 flex flex-wrap items-center gap-2 text-xl font-bold sm:text-2xl md:text-3xl">
      <span aria-hidden="true">🧠</span> Perfil deportivo
    </h2>
    <div class="prose prose-invert prose-sm max-w-none text-base-content/90 sm:prose-base">
      <p>
        Triatleta amateur competitivo con una rápida evolución en el deporte, destacándome en pruebas de corta y media
        distancia.
      </p>
      <p>
        En menos de 2 años logré posicionarme entre los mejores atletas de mi categoría, acumulando podios recurrentes y
        alcanzando la clasificación al Mundial de Ironman 70.3.
      </p>
    </div>
    <div class="mt-6">
      <p class="font-semibold mb-3 opacity-90">🔥 Comprometido con:</p>
      <ul class="flex flex-wrap gap-2">
        {
          [
            "Alto rendimiento",
            "Entrenamiento constante",
            "Mejora continua",
            "Disciplina y mentalidad competitiva",
          ].map((t) => (
            <li class="badge badge-primary badge-sm sm:badge-lg">{t}</li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Logros -->
  <section id="logros" class="scroll-mt-24 mb-12 sm:mb-14">
    <h2 class="mb-5 flex flex-wrap items-center gap-2 text-xl font-bold sm:mb-6 sm:text-2xl md:text-3xl">
      <span aria-hidden="true">🏆</span> Logros destacados
    </h2>
    <ul class="grid gap-3 md:gap-4">
      <li class="flex gap-3 items-start rounded-lg border border-base-300/60 bg-base-200/60 p-3 sm:p-4">
        <span class="text-2xl shrink-0" aria-hidden="true">🥇</span>
        <span class="min-w-0 text-sm leading-snug sm:text-base">Clasificación al Mundial IRONMAN 70.3 World Championship – Niza 2026</span>
      </li>
      <li class="flex gap-3 items-start rounded-lg border border-base-300/60 bg-base-200/60 p-3 sm:p-4">
        <span class="text-2xl shrink-0" aria-hidden="true">🏁</span>
        <span class="min-w-0 text-sm leading-snug sm:text-base">Finisher Ironman Brasil (Full) – 10h05 (debut)</span>
      </li>
      <li class="flex gap-3 items-start rounded-lg border border-base-300/60 bg-base-200/60 p-3 sm:p-4">
        <span class="text-2xl shrink-0" aria-hidden="true">🥉</span>
        <span class="min-w-0 text-sm leading-snug sm:text-base">Podio general – Duatlón Punta Mogotes 2025</span>
      </li>
      <li class="flex gap-3 items-start rounded-lg border border-base-300/60 bg-base-200/60 p-3 sm:p-4">
        <span class="text-2xl shrink-0" aria-hidden="true">🥇</span>
        <span class="min-w-0 text-sm leading-snug sm:text-base">Múltiples podios categoría 40–44 (Short y Sprint)</span>
      </li>
      <li class="flex gap-3 items-start rounded-lg border border-base-300/60 bg-base-200/60 p-3 sm:p-4">
        <span class="text-2xl shrink-0" aria-hidden="true">📊</span>
        <span class="min-w-0 text-sm leading-snug sm:text-base">Top 10% masculino – Ironman 70.3 Buenos Aires 2024</span>
      </li>
      <li class="flex gap-3 items-start rounded-lg border border-base-300/60 bg-base-200/60 p-3 sm:p-4">
        <span class="text-2xl shrink-0" aria-hidden="true">📍</span>
        <span class="min-w-0 text-sm leading-snug sm:text-base">Alta consistencia competitiva (Mar del Plata + Tandil)</span>
      </li>
    </ul>
  </section>

  <!-- Resultados (timeline) -->
  <section id="resultados" class="scroll-mt-24 mb-12 sm:mb-14">
    <h2 class="mb-6 flex flex-wrap items-center gap-2 text-xl font-bold sm:mb-8 sm:text-2xl md:text-3xl">
      <span aria-hidden="true">📊</span> Resultados deportivos
    </h2>
    <ResultsTimeline blocks={RESULTS_TIMELINE} />
  </section>

  <!-- Proyección -->
  <section id="proyeccion" class="scroll-mt-24 mb-12 sm:mb-14">
    <h2 class="mb-4 flex flex-wrap items-center gap-2 text-xl font-bold sm:text-2xl md:text-3xl">
      <span aria-hidden="true">🚀</span> Proyección 2026
    </h2>
    <div class="mb-6 rounded-2xl border border-base-300/60 bg-gradient-to-r from-primary/15 to-secondary/15 p-4 sm:p-5 md:p-6">
      <p class="text-balance text-base font-semibold sm:text-lg">
        🌍 Participación en el Mundial IRONMAN 70.3 World Championship – Niza
      </p>
    </div>
    <div class="mb-6">
      <p class="font-semibold mb-3">🎯 Objetivos:</p>
      <ul class="list-disc list-inside space-y-2 opacity-90">
        <li>Performance competitiva internacional</li>
        <li>Mejorar tiempos en media distancia</li>
        <li>Consolidación en categoría 40–44</li>
      </ul>
    </div>
    <div class="alert border border-warning/50 bg-warning/10 text-base-content">
      <div class="min-w-0 text-sm sm:text-base">
        <p class="font-bold">🔥 Próximo gran desafío</p>
        <p class="mt-1">🏁 Ironman Full San Juan 2026</p>
        <p class="mt-2 opacity-90">🎯 Camino hacia clasificación a Kona (Hawaii)</p>
      </div>
    </div>
  </section>

  <!-- Sponsorship -->
  <section id="sponsorship" class="scroll-mt-24 mb-12 sm:mb-14">
    <h2 class="mb-4 flex flex-wrap items-center gap-2 text-xl font-bold sm:text-2xl md:text-3xl">
      <span aria-hidden="true">🤝</span> Propuesta de sponsorship
    </h2>
    <p class="mb-6 max-w-2xl text-sm text-base-content/90 sm:text-base">
      Busco generar alianzas estratégicas con marcas que quieran acompañar este camino hacia el Mundial.
    </p>
    <div>
      <p class="font-semibold mb-4">📢 ¿Qué ofrezco?</p>
      <ul class="grid sm:grid-cols-2 gap-3">
        <li class="flex gap-2 items-start rounded-lg border border-base-300/50 bg-base-200/70 p-3 sm:p-4">
          <span class="shrink-0" aria-hidden="true">📱</span>
          <span class="min-w-0 text-sm leading-snug sm:text-base">Presencia en redes (entrenamiento + competencia + lifestyle)</span>
        </li>
        <li class="flex gap-2 items-start rounded-lg border border-base-300/50 bg-base-200/70 p-3 sm:p-4">
          <span class="shrink-0" aria-hidden="true">🎥</span>
          <span class="min-w-0 text-sm leading-snug sm:text-base">Contenido audiovisual (previo y durante el Mundial)</span>
        </li>
        <li class="flex gap-2 items-start rounded-lg border border-base-300/50 bg-base-200/70 p-3 sm:p-4">
          <span class="shrink-0" aria-hidden="true">🏁</span>
          <span class="min-w-0 text-sm leading-snug sm:text-base">Exposición de marca en carreras</span>
        </li>
        <li class="flex gap-2 items-start rounded-lg border border-base-300/50 bg-base-200/70 p-3 sm:p-4">
          <span class="shrink-0" aria-hidden="true">📖</span>
          <span class="min-w-0 text-sm leading-snug sm:text-base">Storytelling del proceso deportivo</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- Contacto -->
  <section id="contacto" class="scroll-mt-24 mb-12 sm:mb-14">
    <h2 class="mb-5 flex flex-wrap items-center gap-2 text-xl font-bold sm:mb-6 sm:text-2xl md:text-3xl">
      <span aria-hidden="true">📲</span> Contacto
    </h2>
    <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:gap-4">
      <a
        href={INSTAGRAM_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary min-h-12 w-full gap-2 sm:w-auto sm:min-h-12"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
          ><path
            d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
          ></path></svg
        >
        Instagram @fransempe
      </a>
      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-success min-h-12 w-full gap-2 text-success-content sm:w-auto"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
          ><path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.521-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.881 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
          ></path></svg
        >
        WhatsApp
      </a>
      <a href={`mailto:${CONTACT_EMAIL}`} class="btn btn-outline min-h-12 w-full gap-2 break-all sm:w-auto sm:break-normal">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"
          ><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg
        >
        {CONTACT_EMAIL}
      </a>
    </div>
  </section>

  <!-- Galería (al final) -->
  <section id="galeria" class="scroll-mt-24 mb-6 sm:mb-8">
    <h2 class="mb-3 flex flex-wrap items-center gap-2 text-xl font-bold sm:mb-4 sm:text-2xl md:text-3xl">
      <span aria-hidden="true">📷</span> Galería
    </h2>
    <p class="mb-4 max-w-2xl text-sm text-base-content/80 sm:mb-6 sm:text-base">
      Entrenamiento, competencias y el camino al Mundial.
    </p>
    <div class="-mx-4 min-w-0 sm:mx-0">
      <ImageCarousel images={CAROUSEL_IMAGES} carouselId="cv" />
    </div>
  </section>
</BaseLayout>
