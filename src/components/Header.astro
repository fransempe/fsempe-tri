---
const { title = "" } = Astro.props;
---

<header
  class="sticky lg:hidden top-0 z-30 w-full border-b border-base-300/40 bg-base-100/90 backdrop-blur-md shadow-sm supports-[backdrop-filter]:bg-base-100/75"
>
  <div class="relative flex min-h-14 items-center justify-between px-1 sm:px-2">
    <!-- Izquierda: menú (ancho fijo para simetría visual) -->
    <div class="flex w-12 shrink-0 items-center justify-start sm:w-14">
      <label
        for="my-drawer"
        class="btn btn-square btn-ghost btn-sm sm:btn-md"
        aria-label="Abrir menú"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          class="h-5 w-5 stroke-current"
          aria-hidden="true"
          ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg
        >
      </label>
    </div>

    <!-- Marca: centrada en todo el ancho del header -->
    <div
      class="pointer-events-none absolute inset-0 flex items-center justify-center px-14 sm:px-16"
    >
      <a
        class="pointer-events-auto btn btn-ghost h-auto min-h-0 shrink gap-1.5 rounded-full px-3 py-1.5 normal-case hover:bg-base-200/80"
        href="/#inicio"
      >
        <span class="max-w-[65vw] truncate text-center text-base font-semibold tracking-tight sm:max-w-none sm:text-lg">
          {title}
        </span>
      </a>
    </div>

    <!-- Derecha: mismo ancho que izquierda (balance óptico) -->
    <div class="w-12 shrink-0 sm:w-14" aria-hidden="true"></div>
  </div>
</header>
