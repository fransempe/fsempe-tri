---
export interface Slide {
  src: string;
  alt: string;
}

interface Props {
  images: Slide[];
  carouselId?: string;
}

const { images, carouselId = "main" } = Astro.props;

if (!images?.length) {
  return null;
}

const prefix = `${carouselId}-slide`;
---

<div class="relative min-w-0 w-full">
  <div
    class:list={[
      "touch-pan-x-momentum flex w-full snap-x snap-mandatory overflow-x-auto scroll-smooth overscroll-x-contain",
      "rounded-none border-y border-base-300/60 bg-base-300/30 shadow-inner sm:rounded-2xl sm:border-x",
      "[scrollbar-width:thin] [touch-action:pan-x]",
    ]}
    tabindex="0"
    role="region"
    aria-roledescription="carrusel"
    aria-label="Galería de imágenes"
  >
    {
      images.map((img, i) => {
        const prev = i === 0 ? images.length - 1 : i - 1;
        const next = i === images.length - 1 ? 0 : i + 1;
        return (
          <div
            id={`${prefix}-${i}`}
            class="relative min-w-full shrink-0 snap-center"
          >
            <figure class="relative w-full overflow-hidden sm:rounded-2xl">
              <img
                src={img.src}
                alt={img.alt}
                width={1200}
                height={675}
                sizes="(max-width: 640px) 100vw, 960px"
                class="aspect-[4/3] h-auto w-full max-h-[min(58dvh,560px)] object-cover sm:aspect-video sm:max-h-[min(52vh,520px)]"
                loading={i === 0 ? "eager" : "lazy"}
                decoding="async"
              />
              <div class="pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t from-base-300/95 to-transparent px-3 pb-2.5 pt-10 sm:px-5 sm:pb-3 sm:pt-12">
                <figcaption class="text-center text-xs font-medium text-base-content/95 sm:text-left sm:text-sm md:text-base">
                  {img.alt}
                </figcaption>
              </div>
            </figure>
            <div class="absolute left-1 right-1 top-1/2 flex -translate-y-1/2 justify-between gap-1 sm:left-3 sm:right-3 md:left-4 md:right-4">
              <a
                href={`#${prefix}-${prev}`}
                class="btn btn-circle min-h-11 min-w-11 border-0 bg-base-100/90 text-base-content shadow-md backdrop-blur-sm hover:bg-base-100 sm:min-h-12 sm:min-w-12 md:min-h-14 md:min-w-14"
                aria-label="Imagen anterior"
              >
                <span aria-hidden="true" class="text-xl leading-none sm:text-2xl">‹</span>
              </a>
              <a
                href={`#${prefix}-${next}`}
                class="btn btn-circle min-h-11 min-w-11 border-0 bg-base-100/90 text-base-content shadow-md backdrop-blur-sm hover:bg-base-100 sm:min-h-12 sm:min-w-12 md:min-h-14 md:min-w-14"
                aria-label="Imagen siguiente"
              >
                <span aria-hidden="true" class="text-xl leading-none sm:text-2xl">›</span>
              </a>
            </div>
          </div>
        );
      })
    }
  </div>

  <div class="mt-3 flex flex-wrap items-center justify-center gap-2 px-1 sm:mt-4">
    {
      images.map((_, i) => (
        <a
          href={`#${prefix}-${i}`}
          class="btn btn-sm min-h-10 min-w-10 btn-circle btn-ghost border border-base-300/50 hover:border-primary hover:bg-primary/20 sm:btn-md"
          aria-label={`Ir a la imagen ${i + 1}`}
        >
          {i + 1}
        </a>
      ))
    }
  </div>
</div>
